# ── gsvx(Graphiti) 그래프 백엔드 (그래프 뷰 · AI 채팅 · STT→그래프 반영) ──
# 로컬: http://127.0.0.1:8020 · 배포: https://<synapvox-graphiti>.onrender.com
VITE_API_BASE=http://127.0.0.1:8020
# gsvx X-API-Key (공개 데모 키 demo-bio → 프로젝트 P-BIO 매핑)
VITE_API_KEY=demo-bio

# ── STT 통합 API(/api 프록시 대상, 개발 서버 전용) ──
VITE_STT_PROXY_TARGET=http://127.0.0.1:8000

# ── Supabase Auth — Project Settings → API ──
VITE_SUPABASE_URL=https://{project-ref}.supabase.co
VITE_SUPABASE_ANON_KEY=replace-with-supabase-publishable-or-anon-key
