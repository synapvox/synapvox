CLOVA_SPEECH_INVOKE_URL=https://clovaspeech-gw.ncloud.com/external/v1/{domain-id}
CLOVA_SPEECH_SECRET=replace-with-clova-speech-secret
SYNAPVOX_API_HOST=127.0.0.1
SYNAPVOX_API_PORT=8000
OPENAI_API_KEY=
SUPABASE_DB_URL=postgresql://postgres.{project-ref}:{password}@aws-0-{region}.pooler.supabase.com:5432/postgres

# Supabase Auth (backend JWT verification) — Project Settings → API
SUPABASE_URL=https://{project-ref}.supabase.co
SUPABASE_ANON_KEY=replace-with-supabase-publishable-or-anon-key

# 프로젝트 지식 그래프
NEO4J_URI=neo4j+s://replace-with-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=replace-with-neo4j-password
NEO4J_DATABASE=neo4j

# Graphiti 그래프 백엔드(그래프 뷰, AI 채팅, STT/자료 적재의 기본 경로)
GSVX_BASE_URL=http://127.0.0.1:8020
GSVX_API_KEY=demo-bio
GRAPHITI_MODEL=gpt-5-mini
GRAPHITI_DELETE_CONCURRENCY=4

# LangSmith observability
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=synapvox
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=

# 쉼표로 여러 관리자 이메일 지정 가능. 서버가 관리자 API 권한을 검사한다.
SYNAPVOX_ADMIN_EMAILS=root@synapvox.local
